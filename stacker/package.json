{
  "name": "stacker",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "tsc -p tsconfig.integration.json --noEmit && pnpm -r --if-present typecheck",
    "lint": "eslint scripts test --ext .ts && pnpm -r --if-present lint",
    "test": "node ./scripts/run-vitest.mjs",
    "demo:seed": "pnpm exec tsx scripts/seed-demo-merchant.ts",
    "smoke:testnet:single-asset-provide-delegate": "pnpm exec tsx scripts/testnet-smoke-single-asset-provide-delegate.ts",
    "db:generate": "pnpm exec drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "pnpm exec tsx packages/db/scripts/migrate.ts",
    "check": "./scripts/run-local-checks.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@initia/initia.js": "^1.1.0",
    "@types/node": "^24.9.1",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.44.7",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "pg": "^8.16.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4"
  }
}
